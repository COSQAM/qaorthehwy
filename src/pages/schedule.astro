---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import sessionizeData from '../data/sessionize.json';
import { getSchedulePhaseConfig } from '../config/schedule';
import { speakerSlug } from '../lib/speakers';
import {
  formatTime,
  formatDuration,
  isSessionConfirmed,
  getSessionKind,
} from '../lib/sessions';

const base = import.meta.env.BASE_URL;

const schedulePhase = getSchedulePhaseConfig();

const speakerMap = new Map(sessionizeData.speakers.map(s => [s.id, s]));
const roomMap = new Map(sessionizeData.rooms.map(r => [r.id, r]));
const roomOrder = new Map(sessionizeData.rooms.map((r, i) => [r.id, i]));

const showTimes = schedulePhase.showTimes;

const baseSessions = sessionizeData.sessions.filter(isSessionConfirmed);

const displaySessions = showTimes
  ? baseSessions
  : baseSessions.filter((s: any) => !s.isServiceSession);

const orderedSessions = displaySessions.slice().sort((a: any, b: any) => {
  const t = new Date(a.startsAt).getTime() - new Date(b.startsAt).getTime();
  if (t !== 0) return t;
  return (roomOrder.get(a.roomId) ?? 0) - (roomOrder.get(b.roomId) ?? 0);
});
---

<Layout title="Schedule - QA or the Highway">
  <main>
    <PageHeader
      title="Conference Schedule"
      description="Full day of sessions, workshops, and networking opportunities."
    />

    <section class="py-4 px-4">
      <div class="container mx-auto max-w-6xl">
        {schedulePhase.showSchedule && orderedSessions.length > 0 ? (
          <div>
            {schedulePhase.message && (
              <div class="text-center mb-10 bg-blue-50 rounded-lg p-6 border border-blue-200">
                <p class="text-xl font-semibold text-blue-800">{schedulePhase.message.title}</p>
                <p class="text-blue-600 mt-1">{schedulePhase.message.subtitle}</p>
              </div>
            )}

            <div class="text-center mb-10">
              <a
                href="https://qa-or-the-highway-2026.sessionize.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 btn-primary px-6 py-3 rounded-lg font-semibold transition hover:scale-105 transform duration-200"
              >
                Plan your day using our event app!
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>

            <div class="space-y-4">
              {orderedSessions.map((session: any) => {
                const kind = getSessionKind(session);
                const speakers = (session.speakers || [])
                  .map((id: string) => speakerMap.get(id))
                  .filter(Boolean);
                const room = roomMap.get(session.roomId);
                const primarySpeaker = speakers[0] ?? null;
                const speakerUrl = primarySpeaker
                  ? `${base}speakers/${speakerSlug(primarySpeaker)}`
                  : null;
                const duration = formatDuration(session.startsAt, session.endsAt);
                const startTime = formatTime(session.startsAt);

                const isService = kind === 'service';
                const isKeynote = kind === 'keynote';
                const isWorkshop = kind === 'workshop';

                const cardClasses = [
                  'block rounded-lg p-5 sm:p-6 border-l-4 transition-all duration-200',
                  isService
                    ? 'bg-blue-50 border-blue-200'
                    : 'bg-white shadow-md hover:shadow-xl hover:scale-[1.01]',
                ].join(' ');

                const borderColor = isService
                  ? 'var(--color-primary)'
                  : isKeynote
                    ? 'var(--color-accent)'
                    : 'var(--color-primary)';

                const Meta = (
                  <div class="flex flex-wrap items-center gap-x-2 gap-y-2 text-sm text-primary font-semibold mb-2">
                    {startTime && <span>{startTime}</span>}
                    {duration && (
                      <>
                        <span class="text-gray-400">·</span>
                        <span class="text-gray-600 font-normal">{duration}</span>
                      </>
                    )}
                    {room && (
                      <>
                        <span class="text-gray-400">·</span>
                        <span class="text-gray-600 font-normal">{room.name}</span>
                      </>
                    )}
                    {isKeynote && (
                      <span class="ml-auto inline-block text-xs px-3 py-1 rounded-full font-bold uppercase tracking-wide" style="background-color: var(--color-accent); color: var(--color-dark);">
                        Keynote
                      </span>
                    )}
                    {isWorkshop && (
                      <span class="ml-auto inline-block btn-primary text-xs px-3 py-1 rounded-full font-bold uppercase tracking-wide">
                        Workshop
                      </span>
                    )}
                  </div>
                );

                if (isService) {
                  return (
                    <div class={cardClasses} style={`border-left-color: ${borderColor};`}>
                      {Meta}
                      <h3 class="text-lg font-bold text-dark">{session.title}</h3>
                    </div>
                  );
                }

                const Body = (
                  <>
                    {Meta}
                    <h3 class="text-xl font-bold mb-3 text-dark">
                      {session.title}
                    </h3>
                    {session.description && (
                      <p class="text-gray-700 line-clamp-3 text-sm mb-3">
                        {session.description}
                      </p>
                    )}
                    {speakers.length > 0 && (
                      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                        {speakers.map((s: any) => (
                          <div class="flex items-center gap-2">
                            <img
                              src={s.profilePicture}
                              alt={s.fullName}
                              class="w-8 h-8 rounded-full object-cover"
                            />
                            <p class="font-semibold text-dark text-sm">
                              {s.fullName}
                            </p>
                          </div>
                        ))}
                      </div>
                    )}
                  </>
                );

                return speakerUrl ? (
                  <a href={speakerUrl} class={cardClasses} style={`border-left-color: ${borderColor};`}>
                    {Body}
                  </a>
                ) : (
                  <div class={cardClasses} style={`border-left-color: ${borderColor};`}>
                    {Body}
                  </div>
                );
              })}
            </div>
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-xl text-gray-600 mb-4">{schedulePhase.message?.title || 'Schedule coming soon!'}</p>
            <p class="text-gray-500">{schedulePhase.message?.subtitle || "We're working on an amazing lineup of sessions."}</p>
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
