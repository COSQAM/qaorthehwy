---
import Layout from "../../layouts/Layout.astro";
import SocialLink from "../../components/SocialLink.astro";
import sessionizeData from "../../data/sessionize.json";
import { renderDescription } from "../../lib/markdown";
import { formatSessionTime } from "../../lib/sessions";
import { speakerSlug, getCoSpeakerIds } from "../../lib/speakers";

const base = import.meta.env.BASE_URL;

type Session = {
  id: string;
  title: string;
  description?: string;
  startsAt: string | null;
  endsAt: string | null;
  roomId: number;
  speakers: string[];
};

type Room = {
  id: number;
  name: string;
};

type Speaker = {
  id: string;
  firstName: string;
  lastName: string;
  fullName: string;
  bio?: string;
  tagLine?: string;
  profilePicture?: string;
  links: Array<{ url: string; linkType: string; title: string }>;
};

export function getStaticPaths() {
  return sessionizeData.speakers.map((speaker) => ({
    params: { id: speakerSlug(speaker) },
    props: { speaker },
  }));
}

const { speaker } = Astro.props as { speaker: Speaker };

// Get speaker's sessions
const speakerSessions = (sessionizeData.sessions as unknown as Session[]).filter(
  (session) => session.speakers.includes(speaker.id),
);

// Resolve co-speakers (unique, excluding the current speaker)
const speakerById = new Map(
  (sessionizeData.speakers as Speaker[]).map((s) => [s.id, s]),
);
const coSpeakers = getCoSpeakerIds(speakerSessions, speaker.id)
  .map((id) => speakerById.get(id))
  .filter((s): s is Speaker => Boolean(s));

function getRoomName(roomId: number) {
  const rooms = sessionizeData.rooms as Room[];
  const room = rooms.find((r) => r.id === roomId);
  return room ? room.name : "TBA";
}
---

<Layout title={`${speaker.fullName} - QA or the Highway`}>
  <main class="py-16 px-4">
    <div class="container mx-auto max-w-6xl">
      <!-- Back Button -->
      <button
        onclick="history.back()"
        class="inline-flex items-center border-2 border-primary text-primary px-6 py-2 rounded-lg font-semibold hover:bg-primary/10 transition mb-8 cursor-pointer"
        style="border-color: var(--color-primary);"
      >
        <svg
          class="w-5 h-5 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back
      </button>

      <!-- Speaker Profile Section -->
      <div class="grid md:grid-cols-[320px_1fr] gap-8 mb-12">
        <!-- Speaker Image Card -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden h-fit">
          {
            speaker.profilePicture && (
              <img
                src={speaker.profilePicture}
                alt={speaker.fullName}
                class="w-full aspect-square object-cover object-top"
              />
            )
          }
        </div>

        <!-- Speaker Info Card -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden p-8 md:p-12 h-fit">
          <h1 class="text-4xl font-bold mb-3 text-dark">
            {speaker.fullName}
          </h1>
          {
            speaker.tagLine && (
              <p class="text-xl text-gray-600 mb-6 font-medium">
                {speaker.tagLine}
              </p>
            )
          }
          {
            speaker.bio && (
              <div class="mb-6">
                <h4 class="text-lg font-semibold mb-2 text-dark">About</h4>
                <p class="text-gray-700 leading-relaxed">{speaker.bio}</p>
              </div>
            )
          }
          {
            speaker.links && speaker.links.length > 0 && (
              <div>
                <h4 class="text-lg font-semibold mb-3 text-dark">Connect</h4>
                <div class="flex flex-wrap gap-4">
                  {speaker.links.map((link) => (
                    <SocialLink url={link.url} linkType={link.linkType} showLabel speakerName={speaker.fullName} />
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </div>

      <!-- Co-Speaker Profile(s) -->
      {coSpeakers.map((co) => (
        <div class="grid md:grid-cols-[320px_1fr] gap-8 mb-12">
          <a
            href={`${base}speakers/${speakerSlug(co)}`}
            class="bg-white rounded-xl shadow-xl overflow-hidden h-fit block hover:shadow-2xl transition-shadow"
          >
            {co.profilePicture && (
              <img
                src={co.profilePicture}
                alt={co.fullName}
                class="w-full aspect-square object-cover object-top"
              />
            )}
          </a>

          <div class="bg-white rounded-xl shadow-xl overflow-hidden p-8 md:p-12 h-fit">
            <a
              href={`${base}speakers/${speakerSlug(co)}`}
              class="inline-block hover:text-primary transition-colors"
            >
              <h1 class="text-4xl font-bold mb-3 text-dark">{co.fullName}</h1>
            </a>
            {co.tagLine && (
              <p class="text-xl text-gray-600 mb-6 font-medium">{co.tagLine}</p>
            )}
            {co.bio && (
              <div class="mb-6">
                <h4 class="text-lg font-semibold mb-2 text-dark">About</h4>
                <p class="text-gray-700 leading-relaxed">{co.bio}</p>
              </div>
            )}
            {co.links && co.links.length > 0 && (
              <div>
                <h4 class="text-lg font-semibold mb-3 text-dark">Connect</h4>
                <div class="flex flex-wrap gap-4">
                  {co.links.map((link) => (
                    <SocialLink url={link.url} linkType={link.linkType} showLabel speakerName={co.fullName} />
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}

      <!-- Sessions Section -->

      { speakerSessions.length > 0 ? (
          <div class="space-y-6">
            {speakerSessions.map((session) => (
              <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-100">
                <h3 class="text-2xl font-bold mb-4 text-dark">
                  {session.title}
                </h3>

                <div class="flex items-start gap-6 mb-6">
                  <div class="flex items-start gap-3">
                    <svg
                      class="w-6 h-6 text-primary mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    <div>
                      <div class="font-semibold text-dark">Time</div>
                      <div class="text-gray-600">
                        {formatSessionTime(session.startsAt, session.endsAt)}
                      </div>
                    </div>
                  </div>

                  <div class="flex items-start gap-3">
                    <svg
                      class="w-6 h-6 text-primary mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                    <div>
                      <div class="font-semibold text-dark">Room</div>
                      <div class="text-gray-600">
                        {getRoomName(session.roomId)}
                      </div>
                    </div>
                  </div>
                </div>

                {session.description && (
                  <div>
                    <h4 class="font-semibold text-lg mb-2 text-dark">
                      Description
                    </h4>
                    <div
                      class="session-description text-gray-700 leading-relaxed"
                      set:html={renderDescription(session.description)}
                    />
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-gray-50 rounded-xl p-8 text-center">
            <p class="text-gray-600">No sessions scheduled yet.</p>
          </div>
        )
      }
    </div>
  </main>
</Layout>

<style is:global>
  .session-description {
    line-height: 1.8;
  }
  .session-description p,
  .session-description ul,
  .session-description ol,
  .session-description blockquote,
  .session-description pre,
  .session-description hr,
  .session-description h1,
  .session-description h2,
  .session-description h3,
  .session-description h4 {
    margin-top: 0;
    margin-bottom: 1.5em;
  }
  .session-description > *:last-child {
    margin-bottom: 0;
  }
  .session-description a {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .session-description a:hover {
    text-decoration: none;
  }
  .session-description strong {
    font-weight: 600;
    color: #111827;
  }
  .session-description em {
    font-style: italic;
  }
  .session-description code {
    background: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .session-description pre {
    background: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }
  .session-description pre code {
    background: transparent;
    padding: 0;
  }
  .session-description ul,
  .session-description ol {
    padding-left: 1.5rem;
  }
  .session-description ul {
    list-style: disc;
  }
  .session-description ol {
    list-style: decimal;
  }
  .session-description li + li {
    margin-top: 0.25rem;
  }
  .session-description hr {
    border: 0;
    border-top: 1px solid #e5e7eb;
    margin: 1.5rem 0;
  }
  .session-description blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: #4b5563;
    font-style: italic;
  }
  .session-description h1,
  .session-description h2,
  .session-description h3,
  .session-description h4 {
    font-weight: 600;
    color: #111827;
    margin-top: 1.25rem;
  }
</style>
