---
import Layout from "../../layouts/Layout.astro";
import SocialLink from "../../components/SocialLink.astro";
import sessionizeData from "../../data/sessionize.json";

type Session = {
  id: string;
  title: string;
  description?: string;
  startsAt: string;
  endsAt: string;
  roomId: number;
  speakers: string[];
};

type Speaker = {
  id: string;
  firstName: string;
  lastName: string;
  fullName: string;
  bio?: string;
  tagLine?: string;
  profilePicture?: string;
  links: Array<{ url: string; linkType: string; title: string }>;
};

export function getStaticPaths() {
  return sessionizeData.speakers.map((speaker) => {
    const slug = `${speaker.firstName.toLowerCase()}-${speaker.lastName.toLowerCase()}`;
    return {
      params: { id: slug },
      props: { speaker },
    };
  });
}

const { speaker } = Astro.props as { speaker: Speaker };

// Get speaker's sessions
const speakerSessions = (sessionizeData.sessions as Session[]).filter((session) =>
  session.speakers.includes(speaker.id),
);

// Helper function to get room name
function getRoomName(roomId: number) {
  const room = sessionizeData.rooms.find((r) => r.id === roomId);
  return room ? room.name : "TBA";
}

function formatTime(dateString: string) {
  const date = new Date(dateString);
  return date.toLocaleString("en-US", {
    hour: "numeric",
    minute: "2-digit",
    hour12: true,
  });
}
---

<Layout title={`${speaker.fullName} - QA or the Highway`}>
  <main class="py-16 px-4">
    <div class="container mx-auto max-w-6xl">
      <!-- Back Button -->
      <button
        onclick="history.back()"
        class="inline-flex items-center border-2 border-primary text-primary px-6 py-2 rounded-lg font-semibold hover:bg-primary/10 transition mb-8 cursor-pointer"
        style="border-color: var(--color-primary);"
      >
        <svg
          class="w-5 h-5 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back
      </button>

      <!-- Speaker Profile Section -->
      <div class="grid md:grid-cols-[320px_1fr] gap-8 mb-12">
        <!-- Speaker Image Card -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden h-fit">
          {
            speaker.profilePicture && (
              <img
                src={speaker.profilePicture}
                alt={speaker.fullName}
                class="w-full aspect-square object-cover object-top"
              />
            )
          }
        </div>

        <!-- Speaker Info Card -->
        <div class="bg-white rounded-xl shadow-xl overflow-hidden p-8 md:p-12 h-fit">
          <h1 class="text-4xl font-bold mb-3 text-dark">
            {speaker.fullName}
          </h1>
          {
            speaker.tagLine && (
              <p class="text-xl text-gray-600 mb-6 font-medium">
                {speaker.tagLine}
              </p>
            )
          }
          {
            speaker.bio && (
              <div class="mb-6">
                <h4 class="text-lg font-semibold mb-2 text-dark">About</h4>
                <p class="text-gray-700 leading-relaxed">{speaker.bio}</p>
              </div>
            )
          }
          {
            speaker.links && speaker.links.length > 0 && (
              <div>
                <h4 class="text-lg font-semibold mb-3 text-dark">Connect</h4>
                <div class="flex flex-wrap gap-4">
                  {speaker.links.map((link) => (
                    <SocialLink url={link.url} linkType={link.linkType} showLabel speakerName={speaker.fullName} />
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </div>

      <!-- Sessions Section -->

      { speakerSessions.length > 0 ? (
          <div class="space-y-6">
            {speakerSessions.map((session) => (
              <div class="bg-white rounded-xl shadow-lg p-8 border border-gray-100">
                <h3 class="text-2xl font-bold mb-4 text-dark">
                  {session.title}
                </h3>

                <div class="flex items-start gap-6 mb-6">
                  <div class="flex items-start gap-3">
                    <svg
                      class="w-6 h-6 text-primary mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    <div>
                      <div class="font-semibold text-dark">Time</div>
                      <div class="text-gray-600">
                        {formatTime(session.startsAt)} -{" "}
                        {formatTime(session.endsAt)}
                      </div>
                    </div>
                  </div>

                  <div class="flex items-start gap-3">
                    <svg
                      class="w-6 h-6 text-primary mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                    <div>
                      <div class="font-semibold text-dark">Room</div>
                      <div class="text-gray-600">
                        {getRoomName(session.roomId)}
                      </div>
                    </div>
                  </div>
                </div>

                {session.description && (
                  <div>
                    <h4 class="font-semibold text-lg mb-2 text-dark">
                      Description
                    </h4>
                    <p class="text-gray-700 leading-relaxed">
                      {session.description}
                    </p>
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <div class="bg-gray-50 rounded-xl p-8 text-center">
            <p class="text-gray-600">No sessions scheduled yet.</p>
          </div>
        )
      }
    </div>
  </main>
</Layout>
